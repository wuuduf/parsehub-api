PARSEHUB_API_KEYS=replace-with-a-long-random-key
PARSEHUB_PARSE_TIMEOUT=35
PARSEHUB_CACHE_TTL=300
PARSEHUB_MAX_INPUT_LENGTH=8192
PARSEHUB_MAX_CONCURRENT_PARSE=8
PARSEHUB_RATE_LIMIT_REQUESTS=60
PARSEHUB_RATE_LIMIT_WINDOW=60
PARSEHUB_DOCS_ENABLED=true
PARSEHUB_TOKEN_SECRET=replace-with-at-least-32-random-bytes
PARSEHUB_ADMIN_TOKEN=replace-with-an-independent-admin-password
PARSEHUB_ADMIN_DB_PATH=./data/parsehub-admin.db
PARSEHUB_MEDIA_TOKEN_TTL=600
PARSEHUB_MEDIA_TIMEOUT=60
PARSEHUB_MEDIA_MAX_BYTES=1073741824
PARSEHUB_ALLOW_PRIVATE_MEDIA=false
PARSEHUB_JOB_TTL=3600
PARSEHUB_JOB_MAX_FILES=50
PARSEHUB_JOB_MAX_BYTES=2147483648
PARSEHUB_JOB_MAX_CONCURRENT=2
PARSEHUB_DAILY_QUOTA=1000
PARSEHUB_CIRCUIT_FAILURES=5
PARSEHUB_CIRCUIT_COOLDOWN=60
# Set in multi-replica deployments. Compose sets this automatically.
PARSEHUB_REDIS_URL=
# Optional S3-compatible artifact storage. Install with --extra object-storage.
PARSEHUB_S3_BUCKET=
PARSEHUB_S3_ENDPOINT=
PARSEHUB_S3_REGION=us-east-1

# Optional platform credentials and network settings are consumed by the core.
PARSEHUB_DOUYIN_DEVICE_ID=
PARSEHUB_DOUYIN_IID=
